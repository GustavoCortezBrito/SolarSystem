# ─── DATABASE ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# Desenvolvimento local (PostgreSQL rodando localmente)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/solarsystem"

# Produção (exemplo com Supabase)
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Produção (exemplo com Railway)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/railway"

# Produção (exemplo com Neon)
# DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]/[DATABASE]?sslmode=require"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Secret para criptografia de tokens
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# URL da aplicação
NEXTAUTH_URL="http://localhost:3000"

# ─── OPCIONAL: PROVIDERS OAUTH ────────────────────────────────────────────────
# Google OAuth (https://console.cloud.google.com/)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (https://github.com/settings/developers)
# GITHUB_ID=""
# GITHUB_SECRET=""

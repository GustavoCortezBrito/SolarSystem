// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── AUTENTICAÇÃO ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER") // USER, ADMIN, MANAGER
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  accounts      Account[]
  sessions      Session[]
  companies     CompanyMember[]
  clients       Client[]
  proposals     Proposal[]
  activities    ClientActivity[]
  notifications Notification[]
  cards         Card[]
  columns       Column[]
  calculations  Calculation[]
  files         FileUpload[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── EMPRESAS ─────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?  @unique
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  logo      String?
  
  // Plano e limites SaaS
  plan              String   @default("STARTER") // STARTER, PROFESSIONAL, ENTERPRISE
  maxUsers          Int      @default(3)
  maxClients        Int      @default(1000)
  maxProjects       Int      @default(500)
  storageQuotaGB    Float    @default(5.0)
  
  // Uso atual (atualizado periodicamente)
  storageUsedGB     Float    @default(0.0)
  
  // Billing
  subscriptionId    String?
  subscriptionStatus String? @default("trial") // trial, active, past_due, canceled
  trialEndsAt       DateTime?
  billingCycle      String?  @default("monthly") // monthly, annual
  nextBillingDate   DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  members   CompanyMember[]
  clients   Client[]
  proposals Proposal[]
  boards    Board[]
  files     FileUpload[]

  @@map("companies")
}

model CompanyMember {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      String   @default("MEMBER") // OWNER, ADMIN, MEMBER, VIEWER
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@map("company_members")
}

// ─── CLIENTES ─────────────────────────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String
  cpfCnpj   String?
  
  // Endereço
  address   String?
  city      String?
  state     String?
  zipCode   String?
  
  // Status e valores
  status         String   @default("LEAD") // LEAD, QUALIFIED, PROPOSAL, NEGOTIATION, WON, LOST
  source         String?  // WEBSITE, REFERRAL, SOCIAL_MEDIA, etc
  proposalValue  Float?
  closedValue    Float?
  
  // Metadados
  tags           String[] @default([])
  projectIds     String[] @default([])
  notes          String?  @db.Text
  
  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastContactAt  DateTime?
  
  // Relações
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  String
  creator    User             @relation(fields: [createdBy], references: [id])
  proposals  Proposal[]
  activities ClientActivity[]
  cards      Card[]
  calculations Calculation[]

  @@index([companyId])
  @@index([status])
  @@index([createdBy])
  @@map("clients")
}

model ClientActivity {
  id          String   @id @default(cuid())
  clientId    String
  userId      String
  userName    String
  type        String   // NOTE, CALL, EMAIL, MEETING, STATUS_CHANGE, PROPOSAL_SENT, CARD_MOVED, CARD_ASSIGNED
  description String   @db.Text
  metadata    Json?
  
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([userId])
  @@map("client_activities")
}

// ─── PROPOSTAS ────────────────────────────────────────────────────────────────

model Proposal {
  id         String   @id @default(cuid())
  companyId  String
  clientId   String?
  
  // Cliente (pode ser novo ou existente)
  client     Json     // { name, email, phone, cpfCnpj, address, city, state, zipCode }
  
  // Consumo
  consumption Json    // { monthlyKwh, averageBill, tariff, annualConsumption }
  
  // Sistema
  system     Json     // { totalPower, moduleCount, modules, inverters, optimizers, batteries, estimatedGeneration }
  
  // Financeiro
  financial  Json     // { totalCost, installationCost, equipmentCost, paymentMethods, roi, paybackYears }
  
  // Status
  status     String   @default("RASCUNHO") // RASCUNHO, ENVIADA, ACEITA, REJEITADA
  
  // Timestamps
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sentAt     DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?
  
  // Relações
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientRel Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy String
  creator   User    @relation(fields: [createdBy], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([status])
  @@index([createdBy])
  @@map("proposals")
}

// ─── BOARD (KANBAN) ───────────────────────────────────────────────────────────

model Board {
  id        String   @id @default(cuid())
  companyId String
  name      String   @default("Board Principal")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  columns Column[]

  @@unique([companyId])
  @@map("boards")
}

model Column {
  id       String @id @default(cuid())
  boardId  String
  title    String
  color    String @default("#3b82f6")
  order    Int
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  createdBy String
  creator   User   @relation(fields: [createdBy], references: [id])
  board     Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]

  @@index([boardId])
  @@map("columns")
}

model Card {
  id          String   @id @default(cuid())
  columnId    String
  title       String
  description String?  @db.Text
  order       Int
  
  // Vinculação com cliente
  clientId    String?
  clientName  String?
  
  // Metadados
  tags        String[] @default([])
  dueDate     DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  column      Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([columnId])
  @@index([clientId])
  @@map("cards")
}

// ─── NOTIFICAÇÕES ─────────────────────────────────────────────────────────────

model Notification {
  id                 String   @id @default(cuid())
  userId             String
  type               String   // NOVO_CLIENTE, PROPOSTA_ACEITA, PROPOSTA_REJEITADA, CARD_MOVIDO, etc
  title              String
  message            String   @db.Text
  read               Boolean  @default(false)
  
  // Ação
  actionUrl          String?
  actionLabel        String?
  
  // Entidade relacionada
  relatedEntityId    String?
  relatedEntityType  String?  // CLIENT, PROPOSAL, CARD
  
  // Origem
  fromUserId         String?
  fromUserName       String?
  
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

// ─── CATÁLOGOS DE EQUIPAMENTOS ───────────────────────────────────────────────

model Module {
  id           String  @id @default(cuid())
  manufacturer String
  model        String
  power        Int     // Watts
  efficiency   Float
  warranty     Int     // Anos
  price        Float
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("modules")
}

model Inverter {
  id           String  @id @default(cuid())
  manufacturer String
  model        String
  power        Int     // Watts
  efficiency   Float
  warranty     Int     // Anos
  price        Float
  phases       Int     @default(1) // 1 ou 3
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inverters")
}

model Battery {
  id           String  @id @default(cuid())
  manufacturer String
  model        String
  capacity     Float   // kWh
  voltage      Int     // V
  warranty     Int     // Anos
  price        Float
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("batteries")
}

model Optimizer {
  id           String  @id @default(cuid())
  manufacturer String
  model        String
  power        Int     // Watts
  efficiency   Float
  warranty     Int     // Anos
  price        Float
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("optimizers")
}

// ─── CÁLCULOS SOLARES ─────────────────────────────────────────────────────────

model Calculation {
  id        String   @id @default(cuid())
  companyId String
  clientId  String?
  
  // Inputs
  propertyType       String   // residential, commercial, industrial
  monthlyConsumption Float    // kWh
  monthlyBill        Float    // R$
  tariff             Float    // R$/kWh
  solarIrradiation   Float    // kWh/m²/dia
  roofType           String   // ceramic, metallic, concrete, fibrociment
  panelPowerWp       Int      // Watts
  systemType         String   // on-grid, off-grid, hybrid
  hasBattery         Boolean  @default(false)
  
  // Resultados
  systemPowerKWp     Float
  numberOfPanels     Int
  inverterPowerKW    Float
  monthlyGeneration  Float
  annualGeneration   Float
  systemCost         Float
  monthlySavings     Float
  annualSavings      Float
  paybackYears       Float
  roi25Years         Float
  requiredAreaM2     Float
  co2AvoidedKgYear   Float
  treesEquivalent    Int
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  createdBy String
  creator   User    @relation(fields: [createdBy], references: [id])
  client    Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([clientId])
  @@index([createdBy])
  @@map("calculations")
}


// ─── CONTROLE DE ARQUIVOS E STORAGE ───────────────────────────────────────────

model FileUpload {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  
  // Arquivo
  fileName    String
  fileSize    Int      // bytes
  fileSizeMB  Float    // megabytes (calculado)
  mimeType    String
  storagePath String   // caminho no Supabase Storage
  storageUrl  String?  // URL pública (se aplicável)
  
  // Vinculação (a que entidade pertence)
  entityType  String?  // CLIENT, PROJECT, PROPOSAL, CARD, IMPORT
  entityId    String?
  
  // Metadata
  uploadedAt  DateTime @default(now())
  deletedAt   DateTime?
  
  // Relações
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
  
  @@index([companyId])
  @@index([entityType, entityId])
  @@index([uploadedAt])
  @@map("file_uploads")
}
